---
import type { RadarItemVM } from '../../lib/data/radarView';

interface Props {
  item: RadarItemVM;
}
const { item } = Astro.props;
---
<div class={`radar-item priority-${item.priority}`}>
  <h3>{item.title}</h3>
  <p>{item.summary}</p>
  {item.relatedLinks.length > 0 && (
    <div class="radar-links">
      {item.relatedLinks.map(link => <a href={link.url}>{link.label}</a>)}
    </div>
  )}
</div>
<style>
  .radar-item {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-4);
    border-left: 4px solid var(--color-border);
    background: var(--color-bg-alt);
  }
  .priority-high { border-color: #d93025; background: #fce8e6; }
  .priority-medium { border-color: #f29900; background: #fef7e0; }
  .priority-low { border-color: #1a73e8; background: #e8f0fe; }
  .radar-item h3 { margin-top: 0; margin-bottom: var(--space-2); }
  .radar-item p { margin-bottom: var(--space-3); }
  .radar-links a { font-weight: 500; color: var(--color-focus); margin-right: var(--space-3); text-decoration: none; }
  .radar-links a:hover { text-decoration: underline; }
</style>

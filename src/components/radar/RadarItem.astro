---
import type { RadarItemVM } from '../../lib/data/radarView';

interface Props {
  item: RadarItemVM;
}
const { item } = Astro.props;
---
<div class={`radar-item priority-${item.priority}`}>
  <h2>{item.title}</h2>
  <p>{item.summary}</p>
  {item.relatedLinks.length > 0 && (
    <div class="radar-links">
      {item.relatedLinks.map(link => <a href={link.url}>{link.label}</a>)}
    </div>
  )}
</div>
<style>
  .radar-item {
    padding: var(--space-4);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-4);
    border-left: 4px solid var(--color-border);
    background: var(--color-bg-alt);
  }
  .priority-high { border-color: #f87171; background: rgba(127, 29, 29, 0.28); }
  .priority-medium { border-color: #fbbf24; background: rgba(120, 53, 15, 0.24); }
  .priority-low { border-color: #60a5fa; background: rgba(30, 64, 175, 0.22); }
  .radar-item h2 { margin-top: 0; margin-bottom: var(--space-2); font-size: 1rem; }
  .radar-item p { margin-bottom: var(--space-3); }
  .radar-links a { font-weight: 500; color: var(--color-focus); margin-right: var(--space-3); text-decoration: none; }
  .radar-links a:hover { text-decoration: underline; }
</style>

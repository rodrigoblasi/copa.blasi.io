---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---
<nav class="site-nav">
  <div class="nav-inner">
    <a class="nav-brand" href="/">
      <span class="brand-icon">⚽</span>
      <span class="brand-text">Copa 2026</span>
    </a>
    <div class="nav-links">
      <a class={currentPath === "" ? "active" : ""} href="/">Guia</a>
      <a class={currentPath === "calendario" ? "active" : ""} href="/calendario">Calendário</a>
      <a class={currentPath === "brasil" ? "active" : ""} href="/brasil">Brasil</a>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .nav-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-4);
    height: 40px;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--color-text) !important;
    text-decoration: none;
  }
  .brand-icon {
    font-size: 1rem;
  }
  .nav-links {
    display: flex;
    gap: 2px;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: 0.7rem;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: all 0.12s ease;
  }
  .nav-links a:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.06);
  }
  .nav-links a.active {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.1);
  }
</style>

---
import type { BrazilPathVM } from '../../lib/data/brazilPath';
import MatchBlock from '../match/MatchBlock.astro';
import ConditionalOpponent from './ConditionalOpponent.astro';

interface Props {
  pathVM: BrazilPathVM;
}
const { pathVM } = Astro.props;
---
<div class="brazil-path-container">
  <section class="group-stage">
    <h2>Fase de Grupos</h2>
    {pathVM.groupMatches.map(m => <MatchBlock match={m} />)}
    {pathVM.groupMatches.length === 0 && <p>Nenhum jogo encontrado.</p>}
  </section>

  <section class="knockout-stage">
    <h2>Fase Eliminatória</h2>
    {pathVM.knockoutPath.map(kp => (
      <div class="knockout-path-item">
        <h3>{kp.block.round}</h3>
        <ConditionalOpponent info={kp.opponentInfo} />
        {kp.matchDetails && <div class="match-context"><MatchBlock match={kp.matchDetails} /></div>}
      </div>
    ))}
    {pathVM.knockoutPath.length === 0 && <p>Aguardando confirmação de classificação.</p>}
  </section>
</div>
<style>
  .brazil-path-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .knockout-path-item {
    background: var(--color-bg-alt);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-brazil);
    margin-bottom: var(--space-4);
  }
  .knockout-path-item h3 { margin-top: 0; }
  .match-context { margin-top: var(--space-3); }
</style>

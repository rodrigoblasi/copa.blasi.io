---
import type { KnockoutBlock, Match } from '../../lib/data/types';
import { getRoundLabel } from '../../lib/data/roundLabels';
import BracketMatch from './BracketMatch.astro';

interface Props {
  blocks: KnockoutBlock[];
  matches: Match[];
}

const { blocks, matches } = Astro.props;

const roundOrder = ['r32', 'r16', 'qf', 'sf'];
const blockByMatchId = new Map(blocks.filter(block => block.matchId).map(block => [block.matchId!, block]));

function orderedRoundMatches(round: string): Match[] {
  return matches
    .filter(match => match.phaseId === 'knockout' && match.round === round)
    .sort((a, b) => {
      const blockA = blockByMatchId.get(a.id)?.displayOrder ?? 999;
      const blockB = blockByMatchId.get(b.id)?.displayOrder ?? 999;
      return blockA - blockB || `${a.date || ''} ${a.kickoffBrt || ''}`.localeCompare(`${b.date || ''} ${b.kickoffBrt || ''}`);
    });
}

function splitSide(round: string, side: 'left' | 'right'): Match[] {
  const roundMatches = orderedRoundMatches(round);
  const midpoint = Math.ceil(roundMatches.length / 2);
  return side === 'left' ? roundMatches.slice(0, midpoint) : roundMatches.slice(midpoint);
}

const leftRounds = roundOrder.map(round => ({ label: getRoundLabel(round), matches: splitSide(round, 'left') }));
const rightRounds = [...roundOrder].reverse().map(round => ({ label: getRoundLabel(round), matches: splitSide(round, 'right') }));
const finalMatch = matches.find(match => match.phaseId === 'knockout' && getRoundLabel(match.round) === 'Final');
const thirdMatch = matches.find(match => match.phaseId === 'knockout' && getRoundLabel(match.round) === 'Disputa de 3º lugar');
---

<div class="bracket" aria-label="Fase Eliminatória em duas chaves">
  <h2 class="bracket-title">Fase Eliminatória</h2>

  <div class="bracket-layout">
    <div class="bracket-side left">
      {leftRounds.map(round => (
        <div class="bracket-round-col">
          <h3 class="col-label">{round.label}</h3>
          {round.matches.map(match => <BracketMatch match={match} />)}
        </div>
      ))}
    </div>

    <div class="bracket-center">
      {thirdMatch && <BracketMatch match={thirdMatch} centerLabel="Disputa de 3º lugar" />}
      {finalMatch && <BracketMatch match={finalMatch} centerLabel="Final" final />}
    </div>

    <div class="bracket-side right">
      {rightRounds.map(round => (
        <div class="bracket-round-col">
          <h3 class="col-label">{round.label}</h3>
          {round.matches.map(match => <BracketMatch match={match} />)}
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .bracket {
    padding: var(--space-4);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    overflow-x: auto;
  }
  .bracket-title {
    margin: 0 0 var(--space-4);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .bracket-layout {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-4);
    min-width: 920px;
  }
  .bracket-side {
    display: grid;
    grid-template-columns: repeat(4, minmax(120px, 1fr));
    gap: var(--space-2);
  }
  .bracket-center {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    justify-content: center;
    align-items: center;
    min-width: 180px;
  }
  .col-label {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-2);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }
  .bracket-round-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  :global(.bracket-match) {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 5px 6px;
    font-size: 0.6rem;
  }
  :global(.bracket-match.final) {
    border-color: var(--color-phase-final);
    border-width: 2px;
    background: rgba(236, 72, 153, 0.08);
  }
  :global(.bm-round-label) {
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-accent);
    text-align: center;
    margin-bottom: 2px;
  }
  :global(.bm-meta) {
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 2px;
  }
  :global(.bm-label) {
    color: var(--color-text);
    line-height: 1.2;
  }
  :global(.bm-score) {
    color: var(--color-text-muted);
    text-align: center;
    font-weight: 700;
  }
  :global(.bm-venue), :global(.bm-stadium) {
    color: var(--color-text);
    opacity: 0.9;
    margin-top: 2px;
  }
  :global(.bm-stadium) {
    display: block;
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  @media (max-width: 1000px) {
    .bracket-layout {
      grid-template-columns: 1fr;
      min-width: 760px;
    }
    .bracket-center {
      flex-direction: row;
      justify-content: flex-start;
      min-width: 0;
    }
  }
</style>

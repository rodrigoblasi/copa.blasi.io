---
import type { Match } from '../../lib/data/types';
import MatchBlock from '../match/MatchBlock.astro';

interface Props {
  match: Match | null;
  status: string;
}
const { match, status } = Astro.props;
---
<section class="brazil-highlight">
  <h2>Acompanhe o Brasil</h2>
  <p>{status}</p>
  {match && <MatchBlock match={match} />}
</section>
<style>
  .brazil-highlight {
    background: #e8f5e9;
    border-left: 4px solid var(--color-brazil);
    padding: 1rem;
    margin-bottom: 2rem;
    border-radius: 0 8px 8px 0;
  }
  .brazil-highlight h2 { color: var(--color-brazil); margin-top: 0; }
</style>

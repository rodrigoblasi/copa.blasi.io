---
import type { GroupSection, Match } from '../../lib/data/types';
import MatchBlock from '../match/MatchBlock.astro';

interface Props {
  group: GroupSection & { matchesDetails: Match[] };
}
const { group } = Astro.props;
---
<section class="group-section">
  <h3>{group.label}</h3>
  <div class="group-matches">
    {group.matchesDetails.map(m => (
      <MatchBlock match={m} />
    ))}
    {group.matchesDetails.length === 0 && <p class="empty-state">Sem jogos ainda.</p>}
  </div>
</section>
<style>
  .group-section {
    background: white;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 1rem;
  }
  .group-section h3 { margin-top: 0; }
  .empty-state { color: #888; font-size: 0.9rem; }
</style>

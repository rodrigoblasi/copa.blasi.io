---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<header class="tournament-header">
  <h1>{title}</h1>
  <p>Tabelão Oficial - Copa Folheto MVP</p>
</header>
<style>
  .tournament-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--color-border);
  }
  .tournament-header h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem 0;
  }
  .tournament-header p {
    margin: 0;
    color: #666;
  }
</style>

---
import type { Match } from '../../lib/data/types';
import MatchBlock from './MatchBlock.astro';

interface Props {
  date: string;
  matches: Match[];
}
const { date, matches } = Astro.props;

const weekdays = ['Domingo', 'Segunda-feira', 'Terça-feira', 'Quarta-feira', 'Quinta-feira', 'Sexta-feira', 'Sábado'];
const months = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];

function friendlyDay(dateStr: string): string {
  if (!dateStr || dateStr === 'TBD') return 'A definir';
  const [y, m, d] = dateStr.split('-').map(Number);
  const dt = new Date(y, m - 1, d);
  return `${weekdays[dt.getDay()]}, ${d} de ${months[m - 1]}`;
}
---
<div class="calendar-day">
  <h3 class="day-header">{friendlyDay(date)}</h3>
  <div class="day-matches">
    {matches.map(m => <MatchBlock match={m} />)}
  </div>
</div>
<style>
  .calendar-day {
    margin-bottom: var(--space-4);
  }
  .day-header {
    margin: 0 0 var(--space-2) 0;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-1);
  }
  .day-matches {
    display: grid;
    gap: var(--space-2);
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
</style>

---
import type { Match } from '../../lib/data/types';
import Flag from '../shared/Flag.astro';

interface Props {
  match: Match;
  featured?: boolean;
}
const { match, featured = false } = Astro.props;

const isBrazil = match.homeTeamId === 'brasil' || match.awayTeamId === 'brasil';

const weekdays = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
function friendlyDate(dateStr: string | null): string {
  if (!dateStr) return '';
  const [y, m, d] = dateStr.split('-').map(Number);
  const dt = new Date(y, m - 1, d);
  return `${weekdays[dt.getDay()]}, ${String(d).padStart(2,'0')}/${String(m).padStart(2,'0')}`;
}
---

<div class:list={['match-block', { featured, 'brazil-match': isBrazil }]}>
  <div class="match-meta">
    <span class="match-date">{friendlyDate(match.date)}</span>
    <span class="match-time">{match.kickoffBrt}</span>
    {match.city && <span class="match-venue">{match.city}</span>}
  </div>
  <div class="match-teams">
    <div class="team home">
      {match.homeTeamCode && <Flag code={match.homeTeamCode} size={featured ? 'md' : 'sm'} />}
      <span class="team-name">{match.homeTeamName || '?'}</span>
    </div>
    <div class="score-placeholder">
      <span class="score-box">-</span>
      <span class="score-sep">×</span>
      <span class="score-box">-</span>
    </div>
    <div class="team away">
      <span class="team-name">{match.awayTeamName || '?'}</span>
      {match.awayTeamCode && <Flag code={match.awayTeamCode} size={featured ? 'md' : 'sm'} />}
    </div>
  </div>
</div>

<style>
  .match-block {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-3);
    transition: background 0.12s ease;
  }
  .match-block:hover {
    background: var(--color-bg-card-hover);
  }
  .match-block.featured {
    padding: var(--space-3) var(--space-4);
    border-width: 1px;
    box-shadow: var(--shadow-md);
  }
  .match-block.brazil-match {
    border-color: var(--color-brazil-border);
    background: var(--color-brazil-bg);
  }
  .match-meta {
    display: flex;
    gap: var(--space-2);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    margin-bottom: 2px;
  }
  .match-date {
    font-weight: 600;
    color: var(--color-accent);
  }
  .match-venue {
    opacity: 0.6;
  }
  .match-teams {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .team {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 4px;
    min-width: 0;
  }
  .team.home {
    justify-content: flex-end;
    flex-direction: row;
  }
  .team.away {
    justify-content: flex-start;
    flex-direction: row;
  }
  .team-name {
    font-weight: 600;
    font-size: 0.7rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1;
  }
  .featured .team-name {
    font-size: 0.85rem;
  }
  .score-placeholder {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-shrink: 0;
  }
  .score-box {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    width: 1.2rem;
    height: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    color: var(--color-text-muted);
  }
  .featured .score-box {
    width: 1.4rem;
    height: 1.4rem;
    font-size: 0.7rem;
  }
  .score-sep {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    font-weight: 300;
  }
</style>

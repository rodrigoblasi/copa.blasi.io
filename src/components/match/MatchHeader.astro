---
import type { MatchDetailVM } from '../../lib/data/matchDetail';
import StatusLabel from '../status/StatusLabel.astro';

interface Props {
  vm: MatchDetailVM;
}
const { vm } = Astro.props;
const { match, homeTeam, awayTeam } = vm;
const title = `${homeTeam?.name || match.homeTeamLabel || 'A definir'} x ${awayTeam?.name || match.awayTeamLabel || 'A definir'}`;
---
<div class="match-header-hero">
  <h1>{title}</h1>
  <div class="match-meta">
    <span class="phase">{match.phaseId === 'groups' ? 'Fase de Grupos' : match.phaseId === 'knockout' ? 'Fase Eliminatória' : match.phaseId}</span>
    <span class="datetime">{match.date || 'TBD'} • {match.kickoffBrt || 'TBD'} (BRT)</span>
  </div>
  
  <div class="match-teams-large">
    <div class="team">
      <div class="team-name">{homeTeam?.name || 'A definir'}</div>
      {match.score && <div class="score">{match.score.homeGoals ?? '-'}</div>}
    </div>
    <div class="vs">X</div>
    <div class="team">
      {match.score && <div class="score">{match.score.awayGoals ?? '-'}</div>}
      <div class="team-name">{awayTeam?.name || 'A definir'}</div>
    </div>
  </div>

  <div class="match-status-area">
    <StatusLabel state={match.status === 'future' ? match.freshnessState : match.status} />
  </div>
</div>
<style>
  .match-header-hero {
    background: var(--color-bg-alt);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    text-align: center;
    margin-bottom: var(--space-6);
  }
  .match-header-hero h1 {
    margin: 0 0 var(--space-3);
    font-size: 1.4rem;
  }
  .match-meta {
    margin-bottom: var(--space-4);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  .phase { text-transform: uppercase; font-weight: 600; margin-right: var(--space-2); }
  .match-teams-large {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-4);
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: var(--space-4);
  }
  .team {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .score {
    background: #fff;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }
  .vs {
    font-size: 1.2rem;
    color: var(--color-text-muted);
  }
</style>

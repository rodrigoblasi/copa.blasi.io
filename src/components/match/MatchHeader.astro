---
import type { MatchDetailVM } from '../../lib/data/matchDetail';
import { getRoundLabel } from '../../lib/data/roundLabels';
import { translateSlotLabel } from '../../lib/data/slotLabels';
import { getScoreDisplay } from '../../lib/data/scoreDisplay';
import StatusLabel from '../status/StatusLabel.astro';

interface Props {
  vm: MatchDetailVM;
}
const { vm } = Astro.props;
const { match, homeTeam, awayTeam } = vm;
const phaseLabel = match.phaseId === 'groups'
  ? 'Fase de Grupos'
  : match.phaseId === 'knockout'
    ? 'Fase Eliminatória'
    : 'A definir';
const title = `${homeTeam?.name || translateSlotLabel(match.homeTeamLabel) || 'A definir'} x ${awayTeam?.name || translateSlotLabel(match.awayTeamLabel) || 'A definir'}`;
const dateLabel = match.date || 'A definir';
const kickoffLabel = match.kickoffBrt || 'A definir';
const scoreLabel = getScoreDisplay(match);
const roundLabel = getRoundLabel(match.round);
---
<div class="match-header-hero">
  <h1>{title}</h1>
  <div class="match-meta">
    <span class="phase">{phaseLabel}</span>
    {match.round && <span class="round">{roundLabel}</span>}
    <span class="datetime">{dateLabel} • {kickoffLabel} (BRT)</span>
  </div>
  
  <div class="match-teams-large">
    <div class="team">
      <div class="team-name">{homeTeam?.name || 'A definir'}</div>
      {match.score && <div class="score">{scoreLabel === 'Placar em revisão' ? '—' : (match.score.homeGoals ?? '-')}</div>}
    </div>
    <div class="vs">X</div>
    <div class="team">
      {match.score && <div class="score">{scoreLabel === 'Placar em revisão' ? '—' : (match.score.awayGoals ?? '-')}</div>}
      <div class="team-name">{awayTeam?.name || 'A definir'}</div>
    </div>
  </div>

  <div class="match-status-area">
    <StatusLabel state={match.status === 'future' ? match.freshnessState : match.status} />
  </div>
</div>
<style>
  .match-header-hero {
    background: var(--color-bg-alt);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    text-align: center;
    margin-bottom: var(--space-6);
  }
  .match-header-hero h1 {
    margin: 0 0 var(--space-3);
    font-size: 1.4rem;
  }
  .match-meta {
    margin-bottom: var(--space-4);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  .phase { text-transform: uppercase; font-weight: 600; margin-right: var(--space-2); }
  .round {
    font-weight: 600;
    margin-right: var(--space-2);
  }
  .match-teams-large {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-4);
    font-size: 2rem;
    font-weight: bold;
    margin-bottom: var(--space-4);
  }
  .team {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .score {
    background: #fff;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }
  .vs {
    font-size: 1.2rem;
    color: var(--color-text-muted);
  }
</style>
